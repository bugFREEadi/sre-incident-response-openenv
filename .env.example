# -----------------------------------------------------------------------------
# SRE Incident Response OpenEnv
# Example environment file for local development, benchmarking, and the ops
# control plane. Copy this to `.env` and replace placeholder values as needed.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Inference / baseline model settings
# -----------------------------------------------------------------------------

# OpenAI-compatible base URL used by inference.py.
API_BASE_URL=https://api.openai.com/v1

# Model name used by inference.py.
MODEL_NAME=gpt-4.1-mini

# Required for inference.py. Use your provider token here.
HF_TOKEN=replace_me

# Optional compatibility alias for tools expecting OPENAI_API_KEY.
OPENAI_API_KEY=replace_me


# -----------------------------------------------------------------------------
# Core ops control-plane mode
# -----------------------------------------------------------------------------

# advisory_only        -> previews and approvals only, no execution
# approval_required    -> approved actions may execute
# enabled              -> same workflow, intended for tightly controlled automation
OPS_EXECUTION_MODE=advisory_only

# Keep auth enabled in shared or remote environments.
OPS_REQUIRE_AUTH=true

# Set true only for local development if you want the app to bypass bearer auth.
OPS_DISABLE_AUTH_FOR_LOCAL_DEV=false

# Mutating actions still require approvals even in enabled mode.
OPS_APPROVAL_REQUIRED_FOR_MUTATIONS=true

# Require a recent passing drill before leaving advisory_only.
OPS_DRILL_GATE_ENABLED=true
OPS_DRILL_VALIDITY_HOURS=24

# Drill thresholds used by the control plane.
OPS_MINIMUM_DRILL_AVERAGE_SCORE=0.75
OPS_MINIMUM_SCENARIO_SCORE=0.65

# Approval lifetime.
OPS_APPROVAL_TTL_MINUTES=60


# -----------------------------------------------------------------------------
# Guardrails and policy defaults
# -----------------------------------------------------------------------------

# Hard caps enforced before execution.
OPS_MAX_SCALE_REPLICAS=20
OPS_MAX_RATE_LIMIT_RPS=10000

# Rate limit for privileged admin or approver routes.
OPS_ADMIN_RATE_LIMIT_COUNT=20
OPS_ADMIN_RATE_LIMIT_WINDOW_SECONDS=60

# Service and action allowlists. Leave empty to disable the specific allowlist.
OPS_ALLOWED_SERVICES=payments-api,invoice-consumer,checkout-api,identity-service,catalog-api,notification-dispatcher
OPS_ALLOWED_MUTATING_ACTIONS=restart_service,rollback_service,scale_service,set_rate_limit

# Example static policy rules. This must be a single-line JSON array.
OPS_POLICY_RULES_JSON=[{"rule_id":"protect-checkout-scale","description":"Limit checkout scaling until human review","services":["checkout-api"],"action_types":["scale_service"],"max_replicas":4},{"rule_id":"deny-midnight-rollbacks","description":"Block rollbacks during maintenance blackout","action_types":["rollback_service"],"active_from_hour_utc":0,"active_to_hour_utc":5,"deny":true}]


# -----------------------------------------------------------------------------
# Auth tokens and tenant scope
# -----------------------------------------------------------------------------

# Tokens are bearer tokens for /ops/v1/* routes. This must be a single-line JSON
# object where each key is the token value and each value describes the actor.
#
# Roles:
# - viewer
# - operator
# - approver
# - admin
#
# allowed_tenants:
# - ["default"] for a single tenant
# - ["tenant-a","tenant-b"] for a scoped multi-tenant operator
# - ["*"] for global admin
OPS_API_TOKENS_JSON={"viewer-token":{"actor_id":"viewer","roles":["viewer"],"allowed_tenants":["default"]},"operator-token":{"actor_id":"operator","roles":["operator"],"allowed_tenants":["default"]},"approver-token":{"actor_id":"incident-commander","roles":["approver"],"allowed_tenants":["default"]},"admin-token":{"actor_id":"platform-admin","roles":["admin"],"allowed_tenants":["default"]}}


# -----------------------------------------------------------------------------
# Persistence
# -----------------------------------------------------------------------------

# Local sqlite default.
OPS_DATABASE_PATH=data/ops_control_plane.sqlite3

# Optional audit export path.
OPS_AUDIT_JSONL_PATH=data/ops_audit.jsonl

# Optional distributed persistence backend. When set, Postgres is used instead of sqlite.
# Supports plain values and also secret indirection:
# - file:///path/to/secret-file
# - env://ENV_VAR_NAME
# Example:
# OPS_DATABASE_URL=postgresql://user:pass@db.internal:5432/sre_ops
# OPS_DATABASE_URL=env://OPS_DATABASE_URL_SECRET
# OPS_DATABASE_URL=file:///var/run/secrets/ops_database_url
# OPS_DATABASE_URL=


# -----------------------------------------------------------------------------
# Read-only telemetry adapters
# -----------------------------------------------------------------------------

# Loki logs adapter
# OPS_LOKI_BASE_URL=https://loki.internal.example.com
# OPS_LOKI_BEARER_TOKEN=replace_me
# OPS_LOKI_QUERY_TEMPLATE={service="{service}"}

# Prometheus metrics adapter
# OPS_PROMETHEUS_BASE_URL=https://prometheus.internal.example.com
# OPS_PROMETHEUS_BEARER_TOKEN=replace_me
# OPS_PROMETHEUS_QUERY_TEMPLATE=up{job="{service}"}

# ArgoCD deploy history adapter
# OPS_ARGOCD_BASE_URL=https://argocd.internal.example.com
# OPS_ARGOCD_BEARER_TOKEN=replace_me

# Topology from a static JSON file
# OPS_TOPOLOGY_FILE=/absolute/path/to/topology.json

# Or topology from an HTTP service catalog
# OPS_TOPOLOGY_URL=https://service-catalog.internal.example.com/topology
# OPS_TOPOLOGY_BEARER_TOKEN=replace_me


# -----------------------------------------------------------------------------
# Remediation adapter
# -----------------------------------------------------------------------------

# Webhook endpoint that accepts approved remediation requests.
# OPS_REMEDIATION_WEBHOOK_URL=https://automation-gateway.internal.example.com/remediate
# OPS_REMEDIATION_BEARER_TOKEN=replace_me

# Optional status verification endpoint, where {operation_id} is replaced with
# the returned operation id from the remediation webhook.
# OPS_REMEDIATION_STATUS_URL_TEMPLATE=https://automation-gateway.internal.example.com/operations/{operation_id}

# Verification polling behavior.
OPS_REMEDIATION_VERIFY_ATTEMPTS=5
OPS_REMEDIATION_VERIFY_DELAY_SECONDS=1


# -----------------------------------------------------------------------------
# Hugging Face / submission helpers
# -----------------------------------------------------------------------------

# Optional if you want to reuse the same shell env for HF CLI.
# HF_SPACE_ID=PhatWalrus/sre-incident-response-openenv
